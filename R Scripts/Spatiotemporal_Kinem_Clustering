UMAP_DATA <- read_excel("SAMPLE_DATA.xlsx", sheet = "SHAM_HR")

UMAP_DATA <- UMAP_DATA %>% filter(mag >= 0.1, SAMPLE == "S1")

head(UMAP_DATA)

features <- UMAP_DATA %>%
  select(x, y, mag, tan, dx, dy)

# remove rows with NA first
complete_idx <- complete.cases(features)
features <- features[complete_idx, ]
UMAP_DATA <- UMAP_DATA[complete_idx, ]

# Scale features
features_scaled <- scale(features)

# adjust weight for different parameters
weight_factors <- c(x=1, y=1, mag=20, tan=20, dx=5, dy=5)
features_weighted <- sweep(features_scaled, 2, weight_factors, `*`)


set.seed(42)
umap_coords <- umap(
  features_weighted,
  n_neighbors = 30,    # smaller -> more local
  min_dist = 0.3,      # smaller -> tighter clusters
  metric = "euclidean"
  #metric = "cosine"
)
umap_coords <- as.data.frame(umap_coords)
colnames(umap_coords) <- c("UMAP1", "UMAP2")

data_umap <- cbind(UMAP_DATA, umap_coords)



