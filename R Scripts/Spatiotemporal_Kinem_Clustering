

library(readxl)
library(dplyr)
library(ggplot2)
library(uwot)       # UMAP
library(mclust)     # GMM
# in mclust package, the BIC is the negative value of standard BIC, so pick the highest BIC result
library(scales)
library(cluster)    # silhouette scoring
library(RColorBrewer)
library(igraph)
