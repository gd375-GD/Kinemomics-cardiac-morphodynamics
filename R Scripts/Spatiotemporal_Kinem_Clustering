# USER SELECTED # OF CLUSTERS

chosen_G_by_region <- c(
  COM = 3,
  TRA = 4
)

# Initialize lists
sil_region_list <- list()
clustered_list <- list()

for (i in seq_along(data_umap_region)) {
  
  region_data <- data_umap_region[[i]]
  region_name <- unique(region_data$region)
  
  cat("\n======================================\n")
  cat("Processing region:", region_name, "\n")
  cat("======================================\n")
  
  coords <- region_data[, c("UMAP1", "UMAP2")]
  
  # ---- Get user-chosen G ----
  best_G <- chosen_G_by_region[region_name]
  
  if (is.na(best_G)) {
    stop(paste("No chosen G defined for region:", region_name))
  }
  
  cat("Using user-selected G =", best_G, "\n")
  
  # ---- Fit final GMM ----
  best_gmm <- Mclust(coords, G = best_G)
  
  # ---- Compute silhouette ----
  if (length(unique(best_gmm$classification)) > 1) {
    sil <- silhouette(best_gmm$classification, dist(coords))
    mean_sil <- mean(sil[, 3])
  } else {
    sil <- NULL
    mean_sil <- NA
  }
  
  cat("Mean silhouette for region", region_name, "=",
      round(mean_sil, 3), "\n")
  
  # ---- Assign cluster labels ----
  region_data$cluster_gmm_region <-
    paste0(region_name, "_", best_gmm$classification)
  
  # ---- Store per-cluster silhouette ----
  if (!is.null(sil)) {
    sil_df <- data.frame(
      cluster = unique(region_data$cluster_gmm_region),
      silhouette = tapply(sil[, 3],
                          region_data$cluster_gmm_region,
                          mean)
    )
  } else {
    sil_df <- data.frame(
      cluster = unique(region_data$cluster_gmm_region),
      silhouette = NA
    )
  }
  
  sil_region_list[[region_name]] <- sil_df
  clustered_list[[i]] <- region_data
}

data_umap_region_clustered <- do.call(rbind, clustered_list)


cluster_names <- unique(data_umap_region_clustered$cluster_gmm_region)
cluster_colors <- setNames(
  colorRampPalette(brewer.pal(12, "Paired"))(length(cluster_names)),
  cluster_names
)



